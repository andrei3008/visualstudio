# VIS-6 non-production credential contract
# Keep real secrets out of git commits; use local env injection only.

VIS_RUN_MODE=dry-run
VIS_ARTIFACTS_DIR=./artifacts
VIS_TIMEZONE=UTC
VIS_POSTS_PER_CHANNEL=3

# Adapter modes: mock | sandbox
VIS_BLOG_ADAPTER_MODE=mock
VIS_X_ADAPTER_MODE=mock
VIS_INSTAGRAM_ADAPTER_MODE=mock
VIS_YOUTUBE_SHORTS_ADAPTER_MODE=mock

# Optional sandbox tokens (set only in local env, never commit real values)
VIS_BLOG_SANDBOX_TOKEN=
VIS_X_SANDBOX_TOKEN=
VIS_INSTAGRAM_SANDBOX_TOKEN=
VIS_YOUTUBE_SANDBOX_TOKEN=

# Optional retry tuning
VIS_MAX_RETRIES=2

# Optional dry-run failure simulation; keep 0 for deterministic validation
VIS_DRY_RUN_FAILURE_RATE=0
VIS_RANDOM_SEED=20260406
